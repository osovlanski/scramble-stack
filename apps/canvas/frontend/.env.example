# Canvas frontend
# In development, VITE_CANVAS_API_URL is unset and the Vite proxy forwards /api to port 3000.
# In production, set this to the Canvas backend URL (e.g. https://canvas-backend.up.railway.app/api).
VITE_CANVAS_API_URL=
VITE_NEWS_FEED_URL=http://localhost:5174
VITE_SYSTEM_DESIGN_URL=http://localhost:5175

# Optional: backend URLs used by the hub StatsStrip to show activity across apps.
# Leave blank to hide those tiles' stats. In production point to the Railway backend URLs.
VITE_NEWS_FEED_API_URL=http://localhost:3001/api
VITE_SYSTEM_DESIGN_QA_API_URL=http://localhost:3002/api
