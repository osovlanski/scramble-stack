# Canvas backend — required
# Defaults match the postgres + redis services in docker-compose.yml; running
# `npm run dev:all` starts those containers so these values work out of the box.
DATABASE_URL=postgresql://scramble:scramble@localhost:5432/scramble
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars-long
ANTHROPIC_API_KEY=sk-ant-...
FRONTEND_URL=http://localhost:5173

# Canvas backend — optional
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5175
PORT=3000
NODE_ENV=development
REDIS_URL=redis://localhost:6379
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=10
